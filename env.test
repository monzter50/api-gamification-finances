# =============================================================================
# Test environment — safe defaults, committed to the repo.
# =============================================================================

NODE_ENV=test
PORT=3001

# Test DB — separate database name to avoid clobbering dev data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamification_finances_test?schema=public

JWT_SECRET=test-jwt-secret-key
JWT_EXPIRES_IN=1h

API_VERSION=v1
CORS_ORIGIN=http://localhost:3001

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

LOG_LEVEL=error
