# =============================================================================
# Local development template — copy to `.env` and fill in real values.
# This file IS committed; `.env` is NOT.
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- PostgreSQL (used by docker-compose to spin up the DB container) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gamification_finances_dev
POSTGRES_PORT=5432

# ---- Database connection (used by Prisma at runtime) ----
# Running the API directly on the host (`yarn dev`):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gamification_finances_dev?schema=public

# Running the API inside docker-compose: the compose file overrides
# DATABASE_URL to use the in-network host `postgres` automatically.

# ---- JWT ----
JWT_SECRET=change-me-locally
JWT_EXPIRES_IN=7d

# ---- API ----
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=debug

# ---- Reverse proxy ----
# Number of proxy hops in front of this app. 0 = no proxy (default).
# Set to 1 when deployed behind Railway / Render / Heroku / Nginx.
# Set to 2 if you add Cloudflare in front of those.
# NEVER set Express `trust proxy: true` — clients can then spoof their IP.
TRUST_PROXY_HOPS=0

# ---- Statement import / AI extraction ----
# Anthropic API key for Claude vision extraction. Leave BLANK to use the mock
# extractor (canned data). This is a SECRET — set it in the platform's secret
# manager (e.g. Railway dashboard), never commit a real key.
ANTHROPIC_API_KEY=
# Force the mock extractor even when ANTHROPIC_API_KEY is set (useful in tests).
USE_MOCK_EXTRACTION=true
# Max statement-upload size in MB.
MAX_UPLOAD_MB=10

# ---- Image tag (used when pulling/pushing built images) ----
IMAGE_TAG=latest
