generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("user")
  isActive  Boolean  @default(true)
  lastLogin DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  budgets      Budget[]
  accounts     Account[]
}

model Account {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  name         String
  type         String        // 'checking' | 'savings' | 'credit_card' | 'vales'
  balance      Float         @default(0)
  currency     String        @default("MXN")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  incomeItems  IncomeItem[]

  @@index([userId])
}

model Transaction {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  accountId        String
  account          Account  @relation(fields: [accountId], references: [id])
  date             DateTime
  amount           Float
  vendor           String
  description      String?
  type             String   // 'income' | 'expense'
  budgetId         String?
  budget           Budget?  @relation(fields: [budgetId], references: [id])
  incomeItemId     String?
  incomeItem       IncomeItem?  @relation(fields: [incomeItemId], references: [id])
  expenseItemId    String?
  expenseItem      ExpenseItem? @relation(fields: [expenseItemId], references: [id])
  
  // Installment info flattened
  installmentCurrent  Int?
  installmentTotal    Int?
  installmentOriginal Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, type, date])
  @@index([budgetId])
  @@index([incomeItemId])
  @@index([expenseItemId])
  @@index([accountId])
}

model Budget {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  year         Int
  month        Int
  
  incomeItems  IncomeItem[]
  expenseItems ExpenseItem[]
  transactions Transaction[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model IncomeItem {
  id           String        @id @default(uuid())
  budgetId     String
  budget       Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId    String?
  account      Account?      @relation(fields: [accountId], references: [id])
  description  String
  amount       Float
  type         String        // Enum handled as string: 'Debit Card', etc.
  transactions Transaction[]

  @@index([accountId])
}

model ExpenseItem {
  id           String        @id @default(uuid())
  budgetId     String
  budget       Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  description  String
  amount       Float
  type         String        // Enum handled as string: 'Fixed', 'Variable'
  transactions Transaction[]
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([token, userId])
  @@index([expiresAt])
}

