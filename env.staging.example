# =============================================================================
# Staging template — copy to `.env.staging` on the staging host or in CI.
# DO NOT commit `.env.staging`.
# =============================================================================

NODE_ENV=staging
PORT=3000

# ---- Database (Prisma Postgres) ----
# Create a SEPARATE project in https://console.prisma.io for staging
# (don't share the prod DB). Copy the TCP "Direct connection" string —
# NOT the `prisma+postgres://` Accelerate URL (that's for connection pooling).
# IMPORTANT: keep `sslmode=require` — Prisma Postgres refuses non-TLS connections.
DATABASE_URL=postgres://USER:PASS@db.prisma.io:5432/postgres?sslmode=require

# These are placeholders. The embedded Postgres service is disabled in
# docker-compose.staging.yml (profile=never), so values don't matter,
# but Compose still interpolates them — keep them non-empty.
POSTGRES_USER=unused
POSTGRES_PASSWORD=unused
POSTGRES_DB=unused

# ---- JWT (must differ from prod) ----
JWT_SECRET=__staging_jwt_secret__
JWT_EXPIRES_IN=7d

# ---- API ----
API_VERSION=v1
CORS_ORIGIN=https://staging.yourdomain.com

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ---- Logging ----
LOG_LEVEL=info

# ---- Image tag pulled by compose ----
IMAGE_TAG=staging
