    "/api/budgets/{id}": {
      "put": {
        "tags": [
          "Budgets"
        ],
        "summary": "Update budget scalar fields (year, month)",
        "description": "Updates ONLY the budget's own scalar fields. Income and expense items\n**must** be managed via the dedicated nested endpoints:\n\n- `/api/budgets/{id}/income` — add, update, or delete income items\n- `/api/budgets/{id}/expense` — add, update, or delete expense items\n\nSending `incomeItems` or `expenseItems` in this body returns `400`.\nRationale: bulk-replacing items would delete rows referenced by\nTransaction.incomeItemId / expenseItemId, breaking transaction history.\n",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "year": {
                    "type": "integer",
                    "minimum": 2000,
                    "maximum": 2100,
                    "example": 2026
                  },
                  "month": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 11,
                    "example": 3
                  }
                }
              },
              "example": {
                "year": 2026,
                "month": 3
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Budget updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Updated budget"
                    },
                    "message": {
                      "type": "string",
                      "example": "Budget updated successfully"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequestError"
          },
          "401": {
            "$ref": "#/components/responses/UnauthorizedError"
          },
          "404": {
            "$ref": "#/components/responses/NotFoundError"
          }
        }
      }
    },
